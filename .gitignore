# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# local data (sqlite db, encryption key)
/data/

# claude code config + session artifacts (per-developer, not shared)
/.claude/
/.superpowers/

# conductor workspace artifacts (per-workspace scratch, not shared)
/.context/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
